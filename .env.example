# Get a token from @BotFather on Telegram and paste it here.
TELEGRAM_BOT_TOKEN=

# Optional: where to store the SQLite database (defaults to ./fuel_tracker.db)
# FUEL_TRACKER_DB=fuel_tracker.db

# Optional: use a Turso (libSQL) cloud database instead of local SQLite — needed for
# durable storage on hosts without a persistent disk (e.g. Render free web service).
# When both are set, the bot uses Turso. Get them with the `turso` CLI.
# TURSO_DATABASE_URL=libsql://your-db-org.turso.io
# TURSO_AUTH_TOKEN=your-token

# Set automatically by Render for a Web Service (used to run in webhook mode).
# Leave unset locally to use long polling.
# PORT=10000
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
